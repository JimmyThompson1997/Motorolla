{
  "schema": "pucky.recipe_bundle.v1",
  "bundle_id": "vm_dev_volume_down_lab_keywords",
  "version": 1,
  "updated_at": "2026-05-23T18:20:00Z",
  "source": "vm_dev_bundle",
  "recipes": [
    {
      "id": "flashlight",
      "phrases": ["flashlight", "flash light"],
      "match": "exact_utterance",
      "steps": [
        {
          "type": "device",
          "command": "torch.set",
          "args": {
            "enabled": true,
            "auto_off_ms": 600
          }
        }
      ],
      "on_success": {"sound": "soft"},
      "on_failure": {"sound": "low_battery"}
    },
    {
      "id": "photo",
      "phrases": ["photo", "take photo", "take picture", "picture"],
      "match": "exact_utterance",
      "steps": [
        {
          "type": "device",
          "command": "photo.capture",
          "args": {
            "max_width": 1280,
            "timeout_ms": 8000
          }
        }
      ],
      "on_success": {"sound": "soft"},
      "on_failure": {"sound": "low_battery"}
    },
    {
      "id": "location_pin",
      "phrases": ["pin location", "save location", "location"],
      "match": "exact_utterance",
      "steps": [
        {
          "type": "device",
          "command": "location.pin",
          "args": {
            "timeout_ms": 60000,
            "max_cache_age_ms": 30000,
            "publish": false
          }
        }
      ],
      "on_success": {"sound": "soft"},
      "on_failure": {"sound": "low_battery"}
    },
    {
      "id": "screenshot",
      "phrases": ["screenshot", "screen shot", "capture screen", "take screenshot"],
      "match": "exact_utterance",
      "steps": [
        {
          "type": "device",
          "command": "screenshot.capture",
          "args": {
            "publish": true,
            "timeout_ms": 4000
          }
        }
      ],
      "on_success": {"sound": "soft"},
      "on_failure": {"sound": "low_battery"}
    },
    {
      "id": "video_on",
      "phrases": ["video on", "start video", "record video"],
      "match": "exact_utterance",
      "steps": [
        {
          "type": "device",
          "command": "video.capture.start",
          "args": {
            "max_width": 1280,
            "timeout_ms": 8000,
            "max_duration_ms": 60000
          }
        }
      ],
      "reply_text": "Video is on.",
      "on_success": {"sound": "soft"},
      "on_failure": {"sound": "low_battery"}
    },
    {
      "id": "video_off",
      "phrases": ["video off", "stop video"],
      "match": "exact_utterance",
      "steps": [
        {
          "type": "device",
          "command": "video.capture.stop",
          "args": {}
        }
      ],
      "reply_text": "Video turned off.",
      "error_reply_text": "Video was off.",
      "on_success": {"sound": "soft"},
      "on_failure": {"sound": "low_battery"}
    }
  ]
}
