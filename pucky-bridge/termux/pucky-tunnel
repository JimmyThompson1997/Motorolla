#!/data/data/com.termux/files/usr/bin/env sh
set -eu

PUCKY_CONFIG_DIR="${HOME}/.config/pucky"
PUCKY_RUN_DIR="${HOME}/.local/run/pucky"
PUCKY_LOG_DIR="${HOME}/.local/state/pucky"
PUCKY_TUNNEL_ENV="${PUCKY_CONFIG_DIR}/tunnel.env"
PUCKY_SUPERVISOR_PID="${PUCKY_RUN_DIR}/tunnel-supervisor.pid"
PUCKY_LOG_FILE="${PUCKY_LOG_DIR}/tunnel.log"

mkdir -p "$PUCKY_CONFIG_DIR" "$PUCKY_RUN_DIR" "$PUCKY_LOG_DIR"

if [ -f "$PUCKY_TUNNEL_ENV" ]; then
  # shellcheck disable=SC1090
  . "$PUCKY_TUNNEL_ENV"
fi

FLY_HOST="${FLY_HOST:-}"
FLY_PORT="${FLY_PORT:-2222}"
FLY_USER="${FLY_USER:-pucky}"
FLY_KEY="${FLY_KEY:-$HOME/.ssh/pucky_fly_ed25519}"
FLY_PROXY_COMMAND="${FLY_PROXY_COMMAND:-}"
REMOTE_BIND="${REMOTE_BIND:-127.0.0.1:18022}"
LOCAL_TARGET="${LOCAL_TARGET:-127.0.0.1:8022}"
RECONNECT_DELAY_SECONDS="${RECONNECT_DELAY_SECONDS:-10}"

usage() {
  cat <<'EOF'
usage: pucky-tunnel start|stop|status|once
EOF
}

tunnel_command() {
  if [ -z "$FLY_HOST" ]; then
    echo "FLY_HOST is not configured in $PUCKY_TUNNEL_ENV" >&2
    return 2
  fi

  # Do not force -6 here. The Fly host may be IPv6, but the local target is
  # Android's IPv4 loopback. Forcing -6 breaks 127.0.0.1 target resolution.
  if [ -n "$FLY_PROXY_COMMAND" ]; then
    exec ssh -N \
      -i "$FLY_KEY" \
      -p "$FLY_PORT" \
      -o "ProxyCommand=$FLY_PROXY_COMMAND" \
      -o StrictHostKeyChecking=no \
      -o UserKnownHostsFile=/dev/null \
      -o LogLevel=ERROR \
      -o ServerAliveInterval=30 \
      -o ServerAliveCountMax=3 \
      -o ExitOnForwardFailure=yes \
      -R "$REMOTE_BIND:$LOCAL_TARGET" \
      "$FLY_USER@$FLY_HOST"
  fi

  exec ssh -N \
    -i "$FLY_KEY" \
    -p "$FLY_PORT" \
    -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null \
    -o LogLevel=ERROR \
    -o ServerAliveInterval=30 \
    -o ServerAliveCountMax=3 \
    -o ExitOnForwardFailure=yes \
    -R "$REMOTE_BIND:$LOCAL_TARGET" \
    "$FLY_USER@$FLY_HOST"
}

is_running() {
  if [ -f "$PUCKY_SUPERVISOR_PID" ]; then
    pid="$(cat "$PUCKY_SUPERVISOR_PID" 2>/dev/null || true)"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi
  return 1
}

start() {
  if is_running; then
    echo "already running pid=$(cat "$PUCKY_SUPERVISOR_PID")"
    return 0
  fi

  (
    while :; do
      printf '%s starting tunnel to %s:%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$FLY_HOST" "$FLY_PORT" >>"$PUCKY_LOG_FILE"
      if ! "$0" once >>"$PUCKY_LOG_FILE" 2>&1; then
        printf '%s tunnel exited rc=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$?" >>"$PUCKY_LOG_FILE"
      fi
      sleep "$RECONNECT_DELAY_SECONDS"
    done
  ) >/dev/null 2>&1 &

  echo "$!" >"$PUCKY_SUPERVISOR_PID"
  echo "started pid=$(cat "$PUCKY_SUPERVISOR_PID")"
}

stop() {
  if [ -f "$PUCKY_SUPERVISOR_PID" ]; then
    pid="$(cat "$PUCKY_SUPERVISOR_PID" 2>/dev/null || true)"
    if [ -n "$pid" ]; then
      kill "$pid" 2>/dev/null || true
    fi
    rm -f "$PUCKY_SUPERVISOR_PID"
  fi
  pkill -f "^ssh .*${REMOTE_BIND}:${LOCAL_TARGET}" 2>/dev/null || true
  echo "stopped"
}

status() {
  if is_running; then
    supervisor="running"
  else
    supervisor="stopped"
  fi
  ssh_pids="$(pgrep -af "^ssh .*${REMOTE_BIND}:${LOCAL_TARGET}" 2>/dev/null || true)"
  printf '{"ok":true,"schema":"pucky.tunnel.v1","supervisor":"%s","ssh_processes":%s}\n' \
    "$supervisor" \
    "$(printf '%s\n' "$ssh_pids" | jq -R -s 'split("\n") | map(select(length > 0))')"
}

case "${1:-}" in
  start) start ;;
  stop) stop ;;
  status) status ;;
  once) tunnel_command ;;
  *) usage; exit 64 ;;
esac
