#!/usr/bin/env python3
import argparse
import json
import os
import secrets
import shlex
import subprocess
import time
import urllib.parse
from datetime import datetime, timezone
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path


ALLOWED = ("status", "battery", "sensors-list", "storage", "network", "ping")


def now():
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def new_command_id():
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    return f"cmd_{stamp}_{secrets.token_hex(4)}"


class Broker:
    def __init__(self, args):
        self.host = args.termux_host
        self.port = args.termux_port
        self.user = args.termux_user
        self.key = args.termux_key
        self.device_id = args.device
        self.timeout = args.timeout
        self.state_dir = Path(args.state_dir)
        self.config_dir = Path(args.config_dir)
        self.state_dir.mkdir(parents=True, exist_ok=True)
        self.config_dir.mkdir(parents=True, exist_ok=True)
        self.history_file = self.state_dir / "command-history.jsonl"
        self.registry_file = self.config_dir / "device-registry.json"

    def ssh_base(self):
        return [
            "ssh",
            "-i",
            self.key,
            "-p",
            str(self.port),
            "-o",
            "StrictHostKeyChecking=no",
            "-o",
            "UserKnownHostsFile=/dev/null",
            "-o",
            "LogLevel=ERROR",
            "-o",
            "BatchMode=yes",
            "-o",
            f"ConnectTimeout={self.timeout}",
            f"{self.user}@{self.host}",
        ]

    def run(self, argv, timeout):
        try:
            proc = subprocess.run(argv, text=True, capture_output=True, timeout=timeout, check=False)
            return proc.returncode, proc.stdout.strip(), proc.stderr.strip()
        except subprocess.TimeoutExpired:
            return 124, "", f"timeout after {timeout}s"
        except FileNotFoundError:
            return 127, "", f"command not found: {argv[0]}"

    def parse_json(self, text):
        try:
            return json.loads(text)
        except Exception:
            return None

    def append_history(self, entry):
        with self.history_file.open("a", encoding="utf-8") as handle:
            handle.write(json.dumps(entry, sort_keys=True, separators=(",", ":")) + "\n")

    def read_history(self, limit=None):
        if not self.history_file.exists():
            return []
        rows = []
        with self.history_file.open("r", encoding="utf-8") as handle:
            for line in handle:
                line = line.strip()
                if not line:
                    continue
                try:
                    rows.append(json.loads(line))
                except json.JSONDecodeError:
                    rows.append({"ok": False, "parse_error": True, "raw": line})
        return rows[-limit:] if limit is not None else rows

    def load_registry(self):
        if not self.registry_file.exists():
            return {"schema": "pucky.registry.v1", "devices": {}}
        try:
            data = json.loads(self.registry_file.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            return {"schema": "pucky.registry.v1", "devices": {}}
        if not isinstance(data, dict) or not isinstance(data.get("devices"), dict):
            return {"schema": "pucky.registry.v1", "devices": {}}
        return data

    def save_registry(self, registry):
        self.registry_file.write_text(json.dumps(registry, sort_keys=True, indent=2) + "\n", encoding="utf-8")

    def update_registry_from_status(self, status):
        registry = self.load_registry()
        device_id = status.get("device_id") or self.device_id
        registry["devices"][device_id] = {
            "id": device_id,
            "last_seen_at": now(),
            "online": True,
            "transport": {
                "type": "ssh-reverse",
                "host": self.host,
                "port": self.port,
                "user": self.user,
            },
            "android": status.get("android"),
            "battery_percent": ((status.get("battery") or {}).get("percentage")),
            "sensor_count": status.get("sensor_count"),
            "sensors": status.get("sensors"),
            "network": status.get("network"),
        }
        self.save_registry(registry)
        return registry["devices"][device_id]

    def mark_offline(self, error):
        registry = self.load_registry()
        device = registry["devices"].setdefault(self.device_id, {"id": self.device_id})
        device["online"] = False
        device["last_error_at"] = now()
        device["last_error"] = error
        self.save_registry(registry)

    def response_summary(self, response):
        result = response.get("result") if isinstance(response, dict) else None
        if not isinstance(result, dict):
            return None
        battery = result.get("battery") if isinstance(result.get("battery"), dict) else result
        return {
            "battery_percent": battery.get("percentage") if isinstance(battery, dict) else None,
            "device_id": result.get("device_id"),
            "sensor_count": result.get("sensor_count"),
        }

    def execute(self, command, command_id=None, requested_by="puckyctl"):
        if command not in ALLOWED:
            payload = {
                "ok": False,
                "schema": "pucky.broker.v1",
                "timestamp": now(),
                "error": {"message": "command not allowed", "allowed": list(ALLOWED)},
            }
            return 64, payload

        command_id = command_id or new_command_id()
        started_at = now()
        started = time.monotonic()
        remote = "~/bin/pucky-command --id {} --requested-by {} {}".format(
            shlex.quote(command_id),
            shlex.quote(requested_by),
            shlex.quote(command),
        )
        rc, stdout, stderr = self.run(self.ssh_base() + [remote], timeout=self.timeout + 25)
        completed_at = now()
        parsed = self.parse_json(stdout)
        ok = rc == 0 and isinstance(parsed, dict) and bool(parsed.get("ok"))
        error = None if ok else {
            "returncode": rc,
            "stderr": stderr or None,
            "stdout": stdout or None,
            "json_parse_failed": rc == 0 and parsed is None,
        }
        payload = {
            "id": command_id,
            "ok": ok,
            "schema": "pucky.broker.v1",
            "timestamp": completed_at,
            "device": self.device_id,
            "command": command,
            "requested_by": requested_by,
            "started_at": started_at,
            "completed_at": completed_at,
            "duration_ms": int((time.monotonic() - started) * 1000),
            "transport": {
                "host": self.host,
                "port": self.port,
                "user": self.user,
            },
            "response": parsed,
            "error": error,
        }
        self.append_history({**payload, "response_summary": self.response_summary(parsed) if isinstance(parsed, dict) else None})
        if command == "status" and ok and isinstance(parsed.get("result"), dict):
            self.update_registry_from_status(parsed["result"])
        elif not ok:
            self.mark_offline(error)
        return (0 if ok else 1), payload

    def tunnel_check(self):
        command_id = new_command_id()
        started_at = now()
        started = time.monotonic()
        rc, stdout, stderr = self.run(["ss", "-ltnp"], timeout=5)
        listener = [line for line in stdout.splitlines() if f"127.0.0.1:{self.port}" in line]
        public_bind = any(f"0.0.0.0:{self.port}" in line or f"*:{self.port}" in line for line in stdout.splitlines())
        payload = {
            "id": command_id,
            "ok": rc == 0 and bool(listener) and not public_bind,
            "schema": "pucky.broker.v1",
            "command": "tunnel-check",
            "started_at": started_at,
            "completed_at": now(),
            "duration_ms": int((time.monotonic() - started) * 1000),
            "listener": listener,
            "public_bind_detected": public_bind,
            "error": None if rc == 0 else {"returncode": rc, "stderr": stderr},
        }
        self.append_history(payload)
        return (0 if payload["ok"] else 1), payload


class Handler(BaseHTTPRequestHandler):
    broker = None

    def log_message(self, fmt, *args):
        return

    def write_json(self, status, payload):
        data = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def read_json(self):
        length = int(self.headers.get("Content-Length", "0"))
        if length <= 0:
            return {}
        return json.loads(self.rfile.read(length).decode("utf-8"))

    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        query = urllib.parse.parse_qs(parsed.query)
        if parsed.path == "/health":
            self.write_json(200, {"ok": True, "schema": "pucky.broker.health.v1", "timestamp": now()})
            return
        if parsed.path == "/tunnel-check":
            rc, payload = self.broker.tunnel_check()
            self.write_json(200 if rc == 0 else 503, payload)
            return
        if parsed.path == "/devices":
            rc, status = self.broker.execute("status", requested_by="broker-devices")
            registry = self.broker.load_registry()
            devices = []
            if rc == 0 and isinstance(status.get("response"), dict):
                result = status["response"].get("result")
                if isinstance(result, dict):
                    devices.append(self.broker.update_registry_from_status(result))
            if not devices:
                devices = list(registry.get("devices", {}).values())
            self.write_json(200 if devices else 503, {
                "ok": bool(devices) and rc == 0,
                "schema": "pucky.broker.devices.v1",
                "timestamp": now(),
                "devices": devices,
                "error": None if rc == 0 else status.get("error"),
            })
            return
        if parsed.path == "/registry":
            self.write_json(200, self.broker.load_registry())
            return
        if parsed.path == "/history":
            try:
                limit = int(query.get("limit", ["20"])[0])
            except ValueError:
                self.write_json(400, {"ok": False, "error": {"message": "limit must be an integer"}})
                return
            self.write_json(200, {
                "ok": True,
                "schema": "pucky.broker.history.v1",
                "timestamp": now(),
                "history_path": str(self.broker.history_file),
                "entries": self.broker.read_history(limit),
            })
            return
        if parsed.path.startswith("/commands/"):
            command_id = parsed.path.rsplit("/", 1)[-1]
            matches = [entry for entry in self.broker.read_history(None) if entry.get("id") == command_id]
            self.write_json(200 if matches else 404, {
                "ok": bool(matches),
                "schema": "pucky.broker.history.v1",
                "timestamp": now(),
                "id": command_id,
                "entries": matches,
                "error": None if matches else {"message": "command id not found"},
            })
            return
        self.write_json(404, {"ok": False, "error": {"message": "not found"}})

    def do_POST(self):
        if self.path != "/commands":
            self.write_json(404, {"ok": False, "error": {"message": "not found"}})
            return
        try:
            data = self.read_json()
        except Exception as exc:
            self.write_json(400, {"ok": False, "error": {"message": f"invalid json: {exc}"}})
            return
        rc, payload = self.broker.execute(
            data.get("command"),
            command_id=data.get("id"),
            requested_by=data.get("requested_by", "puckyctl"),
        )
        self.write_json(200 if rc == 0 else (400 if rc == 64 else 502), payload)


def build_parser():
    parser = argparse.ArgumentParser(description="Pucky local broker")
    parser.add_argument("--listen-host", default=os.environ.get("PUCKY_BROKER_HOST", "127.0.0.1"))
    parser.add_argument("--listen-port", type=int, default=int(os.environ.get("PUCKY_BROKER_PORT", "18080")))
    parser.add_argument("--termux-host", default=os.environ.get("PUCKY_TERMUX_HOST", "127.0.0.1"))
    parser.add_argument("--termux-port", type=int, default=int(os.environ.get("PUCKY_TERMUX_PORT", "18022")))
    parser.add_argument("--termux-user", default=os.environ.get("PUCKY_TERMUX_USER", "u0_a133"))
    parser.add_argument("--termux-key", default=os.environ.get("PUCKY_TERMUX_KEY", str(Path.home() / ".ssh" / "termux_client_ed25519")))
    parser.add_argument("--device", default=os.environ.get("PUCKY_DEVICE_ID", "xs19pro-001"))
    parser.add_argument("--timeout", type=int, default=int(os.environ.get("PUCKY_TIMEOUT", "10")))
    parser.add_argument("--state-dir", default=os.environ.get("PUCKY_STATE_DIR", str(Path.home() / ".local" / "state" / "pucky")))
    parser.add_argument("--config-dir", default=os.environ.get("PUCKY_CONFIG_DIR", str(Path.home() / ".config" / "pucky")))
    return parser


def main():
    args = build_parser().parse_args()
    Handler.broker = Broker(args)
    server = ThreadingHTTPServer((args.listen_host, args.listen_port), Handler)
    print(json.dumps({
        "ok": True,
        "schema": "pucky.broker.start.v1",
        "listen": f"http://{args.listen_host}:{args.listen_port}",
        "timestamp": now(),
    }), flush=True)
    server.serve_forever()


if __name__ == "__main__":
    main()
